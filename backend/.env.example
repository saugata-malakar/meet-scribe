# ══════════════════════════════════════════════════════════════════
#  MeetScribe Backend — Environment Variables
#  Copy to .env and fill every value before running locally.
# ══════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────
DEBUG=true
FRONTEND_URL=http://localhost:3000

# ── Supabase PostgreSQL ──────────────────────────────────────────
# Dashboard → Project → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ── Clerk ────────────────────────────────────────────────────────
# Dashboard → API Keys
CLERK_DOMAIN=your-app.clerk.accounts.dev
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# ── Google Gemini ─────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ── Google Cloud ─────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Local: path to service account JSON
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Render: base64-encode → base64 -w 0 service-account.json
GOOGLE_CREDENTIALS_JSON=

GCS_BUCKET_NAME=meet-scribe-storage

# ── Upstash Redis ─────────────────────────────────────────────────
# https://console.upstash.com → Create Database → REST API tab
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=AXxx...

# ── Pinecone ──────────────────────────────────────────────────────
# https://app.pinecone.io → API Keys
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=meet-scribe
PINECONE_ENVIRONMENT=us-east-1

# ── Sentry ────────────────────────────────────────────────────────
# https://sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX

# ── PostHog (server-side events) ─────────────────────────────────
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://app.posthog.com

# ── Bot ───────────────────────────────────────────────────────────
BOT_NAME=AI Scribe Bot
MAX_CONCURRENT_BOTS=3
AUDIO_CHUNK_DURATION_MS=10000
MAX_MEETING_DURATION_MINUTES=120
